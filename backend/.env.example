# ── LLM provider ──────────────────────────────────────────────────────────
# Which wrapper llm.py uses: "anthropic" or "openai".
# With no key set, the pipeline runs in deterministic MOCK mode (fine for a
# UI-only demo, but the agent won't actually reason — set a key for that).
LLM_PROVIDER=openai

# ── PwC GenAI Shared Service (RECOMMENDED) ────────────────────────────────
# OpenAI-format proxy (LiteLLM in front of Azure OpenAI). The OpenAI client
# in llm.py talks to it directly — just fill in your key below.
#   - Base URL exposes /v1/chat/completions, so point OPENAI_BASE_URL at /v1.
#   - Auth is your key; the OpenAI SDK sends it as `Authorization: Bearer <key>`.
#   - Requires the PwC corporate network / VPN.
OPENAI_API_KEY=              # <-- paste your PwC GenAI apiKey here
OPENAI_BASE_URL=https://genai-sharedservice-americas.pwc.com/v1
OPENAI_MODEL=azure.gpt-4o-mini      # or azure.gpt-4o for higher-quality drafts

# ── OpenAI (direct, public API) ───────────────────────────────────────────
# To use api.openai.com instead, blank out OPENAI_BASE_URL above and set a
# real OpenAI key + model (e.g. gpt-4o).

# ── Anthropic (direct) ────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=            # optional override / gateway base URL

# ── OmniRoute gateway (OpenAI-compatible, optional) ───────────────────────
# If you run OmniRoute locally instead, set:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=<omniroute dashboard key>
#   OPENAI_BASE_URL=http://localhost:20128/v1
#   OPENAI_MODEL=<model id from the OmniRoute catalog>
